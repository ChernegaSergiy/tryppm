namespace TrypPM.Core;

load "Installer.try";
use TrypPM.Core.Installer;

class Uninstaller {
    fn uninstallPackage(pkgStr) {
        print("Uninstalling " + pkgStr + "...");
        
        if (!File.exists("tryp.json")) {
            print("Error: tryp.json not found in current directory.");
            OS.exit(1);
        }
        
        let file = File.open("tryp.json", "r");
        let contentRes = file.value.read();
        file.value.close();
        
        if (!contentRes.isOk) {
            print("Error reading tryp.json");
            OS.exit(1);
        }
        
        let manifest = Json.parse(contentRes.value);
        if (Map.has(manifest, "dependencies")) {
            let deps = manifest["dependencies"];
            if (Map.has(deps, pkgStr)) {
                Map.remove(deps, pkgStr);
                manifest["dependencies"] = deps;
                
                let outFile = File.open("tryp.json", "w");
                outFile.value.write(Json.stringify(manifest, 4));
                outFile.value.close();
                print("Removed " + pkgStr + " from tryp.json dependencies.");
            } else {
                print("Warning: " + pkgStr + " not found in tryp.json dependencies.");
            }
        }
        
        let parts = String.split(pkgStr, ":");
        if (List.length(parts) > 1) {
            let repoPath = parts[1];
            let pathParts = String.split(repoPath, "/");
            let folderName = pathParts[List.length(pathParts) - 1];
            if (folderName == "") {
                if (List.length(pathParts) > 1) {
                    folderName = pathParts[List.length(pathParts) - 2];
                }
            }
            
            if (folderName != "") {
                let dest = "tryp_modules/" + folderName;
                OS.exec("rm -rf " + dest);
                print("Removed directory " + dest);
            }
        }
        
        print("\nSyncing dependencies and regenerating autoloader...");
        let installer = Installer();
        installer.installManifest();
    }
}
