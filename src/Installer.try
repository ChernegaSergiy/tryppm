namespace TrypPM.Core;

load "Provider.try";
load "GitHubProvider.try";
load "GitLabProvider.try";
load "BitbucketProvider.try";
load "CodebergProvider.try";
load "LocalProvider.try";

use TrypPM.Providers.GitHubProvider;
use TrypPM.Providers.GitLabProvider;
use TrypPM.Providers.BitbucketProvider;
use TrypPM.Providers.CodebergProvider;
use TrypPM.Providers.LocalProvider;

class Installer {
    fn getProviders() {
        return [
            GitHubProvider(),
            GitLabProvider(),
            BitbucketProvider(),
            CodebergProvider(),
            LocalProvider()
        ];
    }

    fn installPackage(pkg) {
        let replaceMap = {};
        let installedMap = {};
        
        let pkgStr = pkg;
        let version = "*";
        
        let parts = String.split(pkg, "@");
        if (List.length(parts) > 1) {
            pkgStr = parts[0];
            version = parts[1];
        }

        let res = this._installWithProviders(pkgStr, version, replaceMap, installedMap);
        if (res) {
            this.generateAutoloader(installedMap);
        }
        return res;
    }

    fn _installWithProviders(pkgStr, requestedVersion, replaceMap, installedMap) {
        let providers = this.getProviders();
        let len = List.length(providers);
        
        let provider = nil;
        let found = false;
        for (let i = 0; i < len; i++) {
            let p = providers[i];
            if (p.supports(pkgStr)) {
                provider = p;
                found = true;
                break;
            }
        }
        
        if (!found) {
            print("Error: No provider found to handle package format '" + pkgStr + "'");
            return false;
        }

        let resolvedVersion = provider.resolveVersion(pkgStr, requestedVersion);
        let basePkg = pkgStr;
        
        if (Map.has(installedMap, basePkg)) {
            let existingVersion = installedMap[basePkg];
            if (existingVersion != resolvedVersion) {
                print("Error: Version conflict for " + basePkg + "!");
                print("Already resolved: " + existingVersion);
                print("Requested now: " + resolvedVersion);
                OS.exit(1);
            }
            return true;
        }
        Map.set(installedMap, basePkg, resolvedVersion);
        
        OS.exec("mkdir -p tryp_modules");
        let targetDir = "tryp_modules";
        
        return provider.install(pkgStr, resolvedVersion, targetDir, replaceMap, installedMap, this);
    }

    fn installDeps(deps, replaceMap, installedMap) {
        let keys = Map.keys(deps);
        let len = List.length(keys);
        
        for (let i = 0; i < len; i++) {
            let key = keys[i];
            let val = deps[key];
            
            let pkgStr = key;
            if (Map.has(replaceMap, key)) {
                pkgStr = "local:" + replaceMap[key];
                val = "LOCAL";
            }
            
            this._installWithProviders(pkgStr, val, replaceMap, installedMap);
        }
    }

    fn installManifest() {
        print("Looking for tryp.json ...");
        if (!File.exists("tryp.json")) {
            print("Error: tryp.json not found in current directory.");
            OS.exit(1);
        }
        
        let file = File.open("tryp.json", "r");
        let contentRes = file.value.read();
        file.value.close();
        
        if (!contentRes.isOk) {
            print("Error reading tryp.json");
            OS.exit(1);
        }
        
        let content = contentRes.value;
        let manifest = Json.parse(content);
        
        let name = Map.has(manifest, "name") ? manifest["name"] : "Unknown";
        let version = Map.has(manifest, "version") ? manifest["version"] : "0.0.0";
        let desc = Map.has(manifest, "description") ? manifest["description"] : "";
        let author = Map.has(manifest, "author") ? manifest["author"] : "Unknown";
        
        print("");
        print("Name: " + name + " v" + version);
        print("Author: " + author);
        if (desc != "") { print("Description: " + desc); }
        print("");
        
        if (!Map.has(manifest, "dependencies")) {
            print("No dependencies found in tryp.json.");
            OS.exit(0);
        }
        
        let deps = manifest["dependencies"];
        let replaceMap = {};
        if (Map.has(manifest, "replace")) {
            replaceMap = manifest["replace"];
            print("Found local overrides in 'replace' block.");
        }
        let installedMap = {};
        
        print("Starting dependency installation...");
        this.installDeps(deps, replaceMap, installedMap);
        
        print("\nAll dependencies installed!");
        this.generateAutoloader(installedMap);
    }
    
    fn generateAutoloader(installedMap) {
        let keys = Map.keys(installedMap);
        let len = List.length(keys);
        if (len == 0) { return; }

        let content = "// Auto-generated by TrypPM\n\n";
        for (let i = 0; i < len; i++) {
            let key = keys[i];
            let parts = String.split(key, ":");
            if (List.length(parts) > 1) {
                if (parts[0] == "github" || parts[0] == "gitlab" || parts[0] == "bitbucket" || parts[0] == "codeberg") {
                    let repoPath = parts[1];
                    let pathParts = String.split(repoPath, "/");
                    if (List.length(pathParts) > 1) {
                        let folderName = pathParts[1];
                        content = content + "load \"" + folderName + "/main.try\";\n";
                    }
                } else if (parts[0] == "local") {
                    let localPath = parts[1];
                    let pathParts = String.split(localPath, "/");
                    let folderName = pathParts[List.length(pathParts) - 1];
                    if (folderName == "") {
                        folderName = pathParts[List.length(pathParts) - 2];
                    }
                    content = content + "load \"" + folderName + "/main.try\";\n";
                }
            }
        }
        
        let file = File.open("tryp_modules/autoload.try", "w");
        if (file.isOk) {
            file.value.write(content);
            file.value.close();
            print("Generated tryp_modules/autoload.try");
        } else {
            print("Failed to generate autoload.try");
        }
    }
}
